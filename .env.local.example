# FitGrant 환경변수 예시 — 이 파일을 .env.local 로 복사해서 값을 채우세요.
# .env.local 은 .gitignore 로 커밋되지 않습니다.

# (선택) Claude 설명 레이어 ON 스위치.
# 비워두면 앱은 룰 기반 설명으로 완전히 동작합니다(무료·환각0).
# 키를 넣으면 결과 카드의 "왜 적합한가요"가 Claude(Haiku)로 더 자연스럽게 재작성됩니다.
# 발급: https://console.anthropic.com  (모델: claude-haiku-4-5, 호출당 ~1.5원 + 캐싱)
ANTHROPIC_API_KEY=

# (선택) Supabase 실연결용 — 관심사업 저장(★)을 DB에 보관합니다.
# 비워두면 관심사업은 브라우저 localStorage 에 저장됩니다(앱은 정상 동작).
# 채우면 Supabase 의 brand_profiles/saved_programs 테이블에 비로그인 session_id 기준으로 저장됩니다.
# 값: Supabase 대시보드 > Settings > API 의 Project URL / anon public 키 (service_role 키 아님!)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# (선택) 마감 알림 이메일 — 아래 3개가 모두 있어야 실제 발송됩니다.
# 없으면 구독 폼은 "비활성화" 안내만 하고 앱은 정상 동작합니다(점진적 향상).
#
# 1) Supabase service_role 키 — 구독/발송 테이블은 서버에서만 접근(브라우저 차단).
#    값: Supabase 대시보드 > Settings > API 의 service_role 키. ⚠️ 절대 클라이언트/깃에 노출 금지.
#    선행: supabase/deadline-notifications.sql 실행으로 테이블 생성.
SUPABASE_SERVICE_ROLE_KEY=

# 2) Resend API 키 — 이메일 발송. 무료 발급: https://resend.com (월 3,000건 무료)
RESEND_API_KEY=
# 발신 주소(선택). 도메인 인증 전에는 onboarding@resend.dev 만 사용 가능.
RESEND_FROM=FitGrant <onboarding@resend.dev>

# 3) 크론 보안 토큰 — Vercel Cron 외 무단 트리거 차단. 임의 문자열 생성해 Vercel 환경변수에도 동일 설정.
#    (Vercel 은 크론 호출 시 Authorization: Bearer <CRON_SECRET> 를 자동 첨부합니다.)
CRON_SECRET=
